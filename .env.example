# ─── Database ────────────────────────────────────────────────
# Postgres connection string (we use Neon). Include ?sslmode=require for hosted DBs.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── Portal JWT / refresh token ─────────────────────────────
# Long random string (>= 32 chars). Used to sign portal access tokens.
JWT_SECRET="replace-me-with-a-long-random-secret-min-32-chars"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_DAYS=30

# ─── App URLs ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Google OAuth (NextAuth) ─────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origin:   http://localhost:3000
# Authorized redirect URI:        http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# NextAuth secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# ─── Builder Hub OAuth (optional second sign-in path) ────────
BUILDER_HUB_URL="https://build.avax.network/"
BUILDER_HUB_REDIRECT_URI="http://localhost:3000/api/auth/builder-hub/callback"
BUILDER_HUB_VALIDATE_URL="https://build.avax.network/api/validate-jwt-token"
NEXT_PUBLIC_BUILDER_HUB_LOGIN_URL="https://build.avax.network"
BUILDER_HUB_CLIENT_ID=""
BUILDER_HUB_CLIENT_SECRET=""

# ─── Discord bot webhook (optional) ─────────────────────────
# Shared secret for POST /api/webhooks/discord/activity.
# The bot must send `Authorization: Bearer <this value>`.
DISCORD_BOT_WEBHOOK_SECRET=""
