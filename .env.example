# ─── Database ────────────────────────────────────────────────
# Postgres connection string (we use Neon). Include ?sslmode=require for hosted DBs.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── Portal JWT / refresh token ─────────────────────────────
# Long random string (>= 32 chars). Used to sign portal access tokens.
JWT_SECRET="replace-me-with-a-long-random-secret-min-32-chars"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_DAYS=30

# ─── App URLs ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Google OAuth (NextAuth) ─────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origin:   http://localhost:3000
# Authorized redirect URI:        http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# NextAuth secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# ─── Builder Hub OAuth (optional second sign-in path) ────────
BUILDER_HUB_URL="https://build.avax.network/"
BUILDER_HUB_REDIRECT_URI="http://localhost:3000/api/auth/builder-hub/callback"
BUILDER_HUB_VALIDATE_URL="https://build.avax.network/api/validate-jwt-token"
NEXT_PUBLIC_BUILDER_HUB_LOGIN_URL="https://build.avax.network"
BUILDER_HUB_CLIENT_ID=""
BUILDER_HUB_CLIENT_SECRET=""

# ─── Email (SMTP) ────────────────────────────────────────────
# Used for support requests and membership notification emails.
# Works with any SMTP provider: Gmail, Resend, SendGrid, Zoho, etc.
#
# Gmail example (use an App Password, not your real password):
#   SMTP_HOST="smtp.gmail.com"
#   SMTP_PORT="587"
#   SMTP_SECURE="false"
#   SMTP_USER="you@gmail.com"
#   SMTP_PASS="xxxx xxxx xxxx xxxx"   ← 16-char App Password
#
# Resend example:
#   SMTP_HOST="smtp.resend.com"
#   SMTP_PORT="465"
#   SMTP_SECURE="true"
#   SMTP_USER="resend"
#   SMTP_PASS="re_xxxxxxxx"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""

# "From" address for outgoing emails. Must match your SMTP sender domain.
MAIL_FROM="team1 Portal <noreply@team1.network>"

# Support inbox — where login-page support form submissions land.
SUPPORT_EMAIL="sarnavo@team1.network"

# ─── Discord bot webhook (optional) ─────────────────────────
# Shared secret for POST /api/webhooks/discord/activity.
# The bot must send `Authorization: Bearer <this value>`.
DISCORD_BOT_WEBHOOK_SECRET=""
