generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ───────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String?
  displayName   String
  username      String?  @unique
  avatarUrl     String?
  bio           String?

  // Required fields (visible to all)
  country       String?
  discord       String?
  xHandle       String?

  // Location
  city          String?
  state         String?

  // Personal
  studentStatus String?  // "undergrad", "graduate", "not_student"
  university    String?
  languages     String?  // JSON array e.g. ["English","Hindi"]

  // Social platforms (individual fields)
  telegram      String?
  github        String?
  linkedin      String?
  instagram     String?
  reddit        String?
  arena         String?
  youtube       String?
  tiktok        String?
  podcast       String?
  blog          String?
  website       String?

  // Profile extras
  walletAddress String?
  skills        String?  // JSON array
  interests     String?  // JSON array
  roles         String?  // JSON array
  availability  String?  // e.g., "Open to Hack", "Just Exploring"
  socialLinks   String?  // JSON array of {name, url} for any custom links
  eventHostingPrefs String? // JSON array e.g. ["Meetup","Workshop","Hackathon"]

  // Lead-only fields (only visible to Global/Region Leads)
  cChainAddress    String?
  developmentGoals String?  @db.Text
  shippingAddress  String?  @db.Text
  merchSizes       String?  // JSON e.g. {"tshirt":"L","hoodie":"XL"}

  // Privacy: JSON object mapping field name -> "public" | "members" | "leads_only"
  // e.g. {"city":"public","email":"members","telegram":"leads_only"}
  // Required fields (country, discord, xHandle) are always public
  // Lead-only fields are always leads_only
  privacySettings String?

  emailVerified Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions      AuthSession[]
  memberships   UserRegionMembership[]
  adminRole     PlatformAdmin?
  playbooks     Playbook[]
  programs      Program[]
  guides        Guide[]
  announcements Announcement[]
  notifications Notification[]
  auditLogs     AuditLog[]
  activities    MemberActivity[]

  @@map("portal_users")
}

model AuthSession {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("portal_auth_sessions")
}

// ─── Member Roster (import whitelist) ───────────────────

model MemberRoster {
  id        String   @id @default(cuid())
  email     String?
  xHandle   String?
  name      String?
  addedById String?
  isUsed    Boolean  @default(false) // marked true once user signs up
  createdAt DateTime @default(now())

  @@unique([email])
  @@map("portal_member_roster")
}

// ─── Member Activities ──────────────────────────────────

model MemberActivity {
  id          String   @id @default(cuid())
  userId      String
  type        String   // "organized_event", "attended_event", "submitted_pr", "created_content", "other"
  title       String
  description String?
  date        DateTime
  link        String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("portal_member_activities")
}

// ─── Regions ────────────────────────────────────────────

model Region {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  country       String?
  description   String?
  logoUrl       String?
  coverImageUrl String?
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  memberships   UserRegionMembership[]
  playbooks     Playbook[]
  programs      Program[]
  guides        Guide[]
  announcements Announcement[]

  @@map("portal_regions")
}

// ─── Membership ─────────────────────────────────────────

model UserRegionMembership {
  id        String   @id @default(cuid())
  userId    String
  regionId  String
  role      String   @default("member") // member, lead, co_lead
  status    String   @default("accepted") // pending, accepted, rejected
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  region Region @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@unique([userId, regionId])
  @@map("portal_user_region_memberships")
}

// ─── Membership Application (no login required) ────────

model MembershipApplication {
  id              String   @id @default(cuid())
  fullName        String
  email           String   @unique
  discord         String
  xHandle         String
  telegram        String?
  github          String?
  country         String
  city            String?
  interests       String?
  interestsOther  String?
  familiarity     String?
  excitement      String?
  portfolioLink   String?
  portfolioContext String?
  timeCommitment  String?
  anythingElse    String?

  status          String   @default("pending")
  reviewedBy      String?
  reviewNote      String?
  reviewedAt      DateTime?
  createdAt       DateTime @default(now())

  @@map("portal_membership_applications")
}

// ─── Content: Playbooks ─────────────────────────────────

model Playbook {
  id            String   @id @default(cuid())
  regionId      String
  title         String
  description   String?
  content       String?  @db.Text
  coverImageUrl String?
  visibility    String   @default("member") // public, member
  status        String   @default("draft") // draft, published
  createdById   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  region  Region @relation(fields: [regionId], references: [id], onDelete: Cascade)
  creator User   @relation(fields: [createdById], references: [id])

  @@map("portal_playbooks")
}

// ─── Content: Programs ──────────────────────────────────

model Program {
  id          String    @id @default(cuid())
  regionId    String
  title       String
  description String?
  content     String?   @db.Text
  eligibility String?
  benefits    String?
  status      String    @default("draft") // draft, active, completed
  startsAt    DateTime?
  endsAt      DateTime?
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  region  Region @relation(fields: [regionId], references: [id], onDelete: Cascade)
  creator User   @relation(fields: [createdById], references: [id])

  @@map("portal_programs")
}

// ─── Content: Guides ────────────────────────────────────

model Guide {
  id            String   @id @default(cuid())
  regionId      String
  title         String
  slug          String   @unique
  category      String?
  content       String?  @db.Text
  coverImageUrl String?
  readTime      Int?
  visibility    String   @default("member") // public, member
  status        String   @default("draft") // draft, published
  createdById   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  region  Region @relation(fields: [regionId], references: [id], onDelete: Cascade)
  creator User   @relation(fields: [createdById], references: [id])

  @@map("portal_guides")
}

// ─── Announcements ──────────────────────────────────────

model Announcement {
  id          String    @id @default(cuid())
  regionId    String?
  title       String
  content     String    @db.Text
  priority    String    @default("normal") // normal, high, urgent
  isGlobal    Boolean   @default(false)
  expiresAt   DateTime?
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  region  Region? @relation(fields: [regionId], references: [id], onDelete: Cascade)
  creator User    @relation(fields: [createdById], references: [id])

  @@map("portal_announcements")
}

// ─── Admin ──────────────────────────────────────────────

model PlatformAdmin {
  id        String   @id @default(cuid())
  userId    String   @unique
  role      String   @default("super_admin") // super_admin
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("portal_platform_admins")
}

// ─── Audit Log ──────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  module     String
  entityType String?
  entityId   String?
  details    String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("portal_audit_logs")
}

// ─── Notifications ──────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("info") // info, success, warning
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("portal_notifications")
}
